{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"Fixed in commit a1cab3b: hardened entrypoint.sh with unconditional state cleanup, two-pass dolt process kill, and final sql-server.info removal before server start","closed_at":"2026-03-03T09:14:14Z","closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":"9ee9b38ab97aea79bc3a94dbbdbb10c4d2115425967bb6d3eec44816a0fae446","created_at":"2026-03-03T09:14:11Z","created_by":"Jørgen Gundersen","crystallizes":0,"defer_until":null,"description":"Stale sql-server.info files survived container restarts because clean_stale_state() used PID-liveness checks (kill -0) which are unreliable across restarts due to PID reuse. This caused 'database is locked' errors and database corruption. Fixed in commit a1cab3b by: (1) removing all state files unconditionally at boot, (2) two-pass kill of ALL dolt sql-server processes, (3) final rm -f of sql-server.info before starting the new server. Also updated bd hooks to 0.58.0 and docs.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"devenv-poj","is_template":0,"issue_type":"bug","last_activity":null,"metadata":"{}","mol_type":"","notes":"","original_size":null,"owner":"jg@gundersenj.com","payload":"","pinned":0,"priority":0,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":"","status":"closed","target":"","timeout_ns":0,"title":"Fix: harden entrypoint dolt lifecycle to prevent database lock errors","updated_at":"2026-03-03T09:14:14Z","waiters":"","wisp_type":"","work_type":""}
