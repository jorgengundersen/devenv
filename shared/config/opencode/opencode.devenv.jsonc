{
    "$schema": "https://opencode.ai/config.json",
	"logLevel": "DEBUG",
    "permission": {
        "*": "allow",
        "bash": {
            "*": "allow",
            "gh *": "deny",
            "git push --force": "deny",
            "git push --force-with-lease": "deny"
        }
    },
    "autoupdate": false
}
