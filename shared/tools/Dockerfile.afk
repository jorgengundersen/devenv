# syntax=docker/dockerfile:1

# Tool: afk (agentic coding loop runner)

FROM tools-go:latest AS go_source

FROM repo-base:latest AS tool_afk
LABEL tools=true

USER root

COPY --from=go_source /usr/local/go /usr/local/go

ENV PATH="/usr/local/go/bin:${PATH}"

RUN go install github.com/jorgengundersen/afk/cmd/afk@latest \
    && mv /root/go/bin/afk /usr/local/bin/afk \
    && chmod +x /usr/local/bin/afk \
    && chown devuser:devuser /usr/local/bin/afk \
    && rm -rf /root/go

USER devuser
