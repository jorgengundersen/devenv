# syntax=docker/dockerfile:1

# Tool: claude-code (Anthropic Claude Code CLI)
# Uses the native installer (npm install is deprecated)

FROM repo-base:latest AS tool_claude-code
LABEL tools=true

# The native installer writes to ~/.local/bin/claude and ~/.local/share/claude.
# Install as devuser so paths land under /home/devuser/.local.
USER devuser

RUN curl -fsSL https://claude.ai/install.sh | bash \
    && ~/.local/bin/claude --version
